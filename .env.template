# .env.template — op:// references only, safe to commit
# Generate .env.local from this file:
#   op inject -i .env.template -o .env.local
#   echo 'APP_URL="http://localhost:5050"' >> .env.local
#
# Secrets are stored in 1Password: vault=celn, item=construction-local-dev

DATABASE_URL=op://celn/construction-local-dev/DATABASE_URL
BETTER_AUTH_SECRET=op://celn/construction-local-dev/BETTER_AUTH_SECRET
RESEND_API_KEY=op://celn/construction-local-dev/RESEND_API_KEY
BLOB_READ_WRITE_TOKEN=op://celn/construction-local-dev/BLOB_READ_WRITE_TOKEN
OPENAI_API_KEY=op://celn/construction-local-dev/OPENAI_API_KEY
BETA_ACCESS_CODE=op://celn/construction-local-dev/BETA_ACCESS_CODE

# APP_URL is dynamic — set manually based on your local port:
# APP_URL="http://localhost:5050"
