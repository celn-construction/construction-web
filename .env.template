# .env.template — reference for required env vars
# Generate .env.local from Vercel:
#   vercel env pull .env.local --environment development --scope celn --yes
#   echo 'APP_URL="http://localhost:5050"' >> .env.local
#
# To add a new secret to Vercel:
#   printf 'value' | vercel env add KEY_NAME development --scope celn --force

construction_POSTGRES_PRISMA_URL=
construction_POSTGRES_URL_NON_POOLING=
BETTER_AUTH_SECRET=
RESEND_API_KEY=
BLOB_READ_WRITE_TOKEN=
OPENAI_API_KEY=
BETA_ACCESS_CODE=

# APP_URL is dynamic — set manually based on your local port:
# APP_URL="http://localhost:5050"
